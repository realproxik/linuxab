{
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer",
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false
    },
    "rust-analyzer.rustfmt.extraArgs": ["--config-path", "${workspaceFolder}/.rustfmt.toml"]
}